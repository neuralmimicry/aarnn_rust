# Build outputs and caches
target
logs
.container-cache
**/__pycache__
*.pyc

# VCS and editor files
.git
.github
.gitignore
.vscode
.idea

# Local runtime junk
outputs
*.log
*.tmp

# Stage only the current container package into the build context.
dist/*
!dist/container/
dist/container/*
!dist/container/*.deb

# Large local/generated content not needed for the container build
webots_world/controllers/**/build
examples/build
