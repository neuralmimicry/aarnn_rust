# Underwater/substrate features for C. elegans navigation
Solid {
  translation -4.29 0.015 3.67
  name "substrate_rocks_nw"
  children [
    Transform { translation 0.3 0 0.4 children [ Shape { appearance PBRAppearance { baseColor 0.42 0.38 0.32 roughness 0.82 } geometry Sphere { radius 0.12 } } ] }
    Transform { translation -0.5 0 -0.2 children [ Shape { appearance PBRAppearance { baseColor 0.44 0.39 0.33 roughness 0.80 } geometry Sphere { radius 0.15 } } ] }
    Transform { translation 0.2 0 -0.6 children [ Shape { appearance PBRAppearance { baseColor 0.40 0.36 0.30 roughness 0.84 } geometry Sphere { radius 0.10 } } ] }
  ]
}
# Logs and natural obstacles
