#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"
EXTERNPROTO "../protos/CelegansRobot.proto"

WorldInfo {
  # Slightly larger time step to keep Webots responsive with articulated
  # multi-robot scenes and clustered controller traffic.
  basicTimeStep 32
  gravity 0 -9.81 0
}
Viewpoint {
  fieldOfView 0.92
  # Zero-roll camera: pitched downward only, so horizon and ground remain level.
  orientation 0.999 0.045 0 1.18
  position 0 15.30 17.85
}
TexturedBackground {
}
TexturedBackgroundLight {
}
# Level world geometry (zero roll), gravity downward (0, -9.81, 0).
RectangleArena {
  floorSize 34.00 34.00
  wallHeight 1.5
}
Solid {
  translation 0 0.005 0
  name "ground_base"
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.36 0.32 0.26
        roughness 0.93
        metalness 0
      }
      geometry Box {
        size 42.00 0.01 42.00
      }
    }
  ]
  boundingObject Box {
    size 42.00 0.01 42.00
  }
}
Solid {
  translation 0 0.011 0
